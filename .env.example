# ==========================================================
# Configuración para DESPLIEGUE CON IA LOCAL (Ollama)
# IMPORTANTE: No subir este archivo a Git con credenciales reales.
# ==========================================================

# --- Motor de IA ---
# 'ollama' = IA local (por defecto, nada sale a internet)
# 'gemini' = IA en la nube de Google (requiere GOOGLE_API_KEYS)
AI_PROVIDER=ollama

# --- Ollama (IA local) ---
# El modelo se elige según el hardware de la VM (ver README).
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_NUM_CTX=8192
# La URL la fija docker-compose automáticamente (http://ollama:11434).
# Solo descomenta si ejecutas la app FUERA de Docker:
# OLLAMA_BASE_URL=http://localhost:11434

# --- Gemini (solo si AI_PROVIDER=gemini) ---
# GOOGLE_API_KEYS=clave1,clave2,clave3
# AI_MODEL=gemini-2.5-flash-lite

# --- Generales ---
LOG_LEVEL=INFO
MAX_RETRIES=2
REQUEST_TIMEOUT=120

# --- OCR (en Docker se fijan solas; para uso local ajusta según tu SO) ---
TESSERACT_PATH=/usr/bin/tesseract
POPPLER_PATH=/usr/bin

# --- Supabase (almacenamiento de los PDF) ---
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_KEY="tu-clave-anon-o-service-role"
SUPABASE_BUCKET="documentos"
